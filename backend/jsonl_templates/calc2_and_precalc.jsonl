{"id":"precalc_trig_001","course":"precalc","topic":"trig_identities","method":"pythagorean_identity","template":"Simplify sin²(x) + {a}cos²(x).","variables":{"a":{"type":"int","range":[1,3],"step":1}},"answer_norm":"1+(a-1)*cos^2(x)","solution_steps":[{"label":"Recall Pythagorean identity","math":"\\sin^2(x) + \\cos^2(x) = 1","note":""},{"label":"Rewrite sin²(x)","math":"\\sin^2(x) = 1 - \\cos^2(x)","note":""},{"label":"Substitute","math":"(1 - \\cos^2(x)) + {a}\\cos^2(x) = 1 + ({a}-1)\\cos^2(x)","note":""}],"contexts":[{"skin":"physics","narrative":"In wave interference, the normalized intensity is sin²(θ) + cos²(θ). Generalize for weighted components."}],"modes_available":["solve","justify","backwards","break"],"justify_foil":"pythagorean_expansion","backwards_prompt":"sin²(x) + cos²(x) = 1. Express sin²(x) in terms of cos²(x).","break_errors":[{"type":"wrong_identity","explanation":"Used sin²(x) = 1 - cos(x) instead of 1 - cos²(x)."}],"tags":["trig","identities","pythagorean"],"difficulty":1}
{"id":"precalc_trig_002","course":"precalc","topic":"trig_equations","method":"solve_trig","template":"Solve 2cos(x) = √3 for x ∈ [0, 2π).","variables":{},"answer_norm":"x=pi/6,x=11pi/6","solution_steps":[{"label":"Isolate cos(x)","math":"\\cos(x) = \\frac{\\sqrt{3}}{2}","note":""},{"label":"Reference angle","math":"\\cos^{-1}\\left(\\frac{\\sqrt{3}}{2}\\right) = \\frac{\\pi}{6}","note":""},{"label":"Find solutions in [0, 2π)","math":"x = \\frac{\\pi}{6}, \\quad x = 2\\pi - \\frac{\\pi}{6} = \\frac{11\\pi}{6}","note":""}],"contexts":[{"skin":"physics","narrative":"The equilibrium position of a damped oscillator satisfies 2cos(x) = √3. Find angles in one period."}],"modes_available":["solve","justify","backwards","break"],"justify_foil":"unit_circle_reference","backwards_prompt":"cos(x) = √3/2. On the unit circle, what angles have cosine = √3/2 in [0, 2π)?","break_errors":[{"type":"quadrant_error","explanation":"Gave only x = π/6, missing the fourth-quadrant solution x = 11π/6."}],"tags":["trig","equations","unit_circle"],"difficulty":1}
{"id":"precalc_log_001","course":"precalc","topic":"logarithms","method":"log_solving","template":"Solve log₂(x² - {a}) = {b}.","variables":{"a":{"type":"int","range":[1,8],"step":1},"b":{"type":"int","range":[1,5],"step":1}},"answer_fn":"sqrt(2**b+a),-sqrt(2**b+a)","answerNorm":"x=sqrt(2^b+a)or-sqrt(2^b+a)","solution_steps":[{"label":"Rewrite in exponential form","math":"x^2 - {a} = 2^{{{b}}}","note":""},{"label":"Solve for x²","math":"x^2 = 2^{{{b}}} + {a} = {2**b + a}","note":""},{"label":"Take square root","math":"x = \\pm \\sqrt{{{2**b + a}}}","note":""},{"label":"Check domain","math":"x^2 - {a} > 0 \\implies x^2 > {a} \\checkmark \\text{ for } \\pm \\sqrt{{{2**b + a}}}","note":""}],"contexts":[{"skin":"computer_science","narrative":"Algorithm complexity: log₂(n² - {a}) = {b}. Find n."}],"modes_available":["solve","justify","backwards","break"],"justify_foil":"log_to_exponential","backwards_prompt":"log₂(x² - {a}) = {b}. Convert to exponential form and solve for x.","break_errors":[{"type":"log_domain_error","explanation":"Forgot that x² - {a} > 0 requires x² > {a}, valid for ±√(2^b + {a})."}],"tags":["logarithms","equations","domain"],"difficulty":1}
{"id":"precalc_exp_001","course":"precalc","topic":"exponential","method":"exp_equations","template":"Solve 3^{x+{a}} = {b}².","variables":{"a":{"type":"int","range":[1,4],"step":1},"b":{"type":"int","range":[2,5],"step":1}},"answer_fn":"2*log(b)/log(3)-a","answerNorm":"2*log_b/ln_3-a","solution_steps":[{"label":"Take ln of both sides","math":"\\ln(3^{x+{a}}) = \\ln({b}^2)","note":""},{"label":"Bring down exponent","math":"(x + {a}) \\ln(3) = 2 \\ln({b})","note":""},{"label":"Solve for x","math":"x + {a} = \\frac{2 \\ln({b})}{\\ln(3)} \\implies x = \\frac{2 \\ln({b})}{\\ln(3)} - {a}","note":""}],"contexts":[{"skin":"biology","narrative":"Cell division: 3^{t+{a}} = {b}². Find t (in hours)."}],"modes_available":["solve","justify","backwards","break"],"justify_foil":"logarithm_exponentiate","backwards_prompt":"3^{x+{a}} = {b}². Take ln of both sides and solve.","break_errors":[{"type":"wrong_log_base","explanation":"Used log_10 instead of ln, or forgot that ln(3^{x+a}) = (x+a)ln3."}],"tags":["exponential","equations","logarithms"],"difficulty":2}
{"id":"precalc_comp_001","course":"precalc","topic":"composition","method":"function_composition","template":"If f(x) = {a}x + {b} and g(x) = x² - {c}, find (f ∘ g)({d}).","variables":{"a":{"type":"int","range":[1,4],"step":1},"b":{"type":"int","range":[1,6],"step":1},"c":{"type":"int","range":[1,5],"step":1},"d":{"type":"int","range":[1,4],"step":1}},"answer_fn":"a*(d**2-c)+b","answerNorm":"a*(d^2-c)+b","solution_steps":[{"label":"Compute g(d)","math":"g({d}) = ({d})^2 - {c} = {d**2 - c}","note":""},{"label":"Apply f to result","math":"f(g({d})) = {a} \\cdot ({d**2 - c}) + {b} = {a*(d**2-c)+b}","note":""}],"contexts":[{"skin":"economics","narrative":"A manufacturing cost is g(units) = units² - {c}. The markup is f(cost) = {a}·cost + {b}. Find the final price for {d} units."}],"modes_available":["solve","justify","backwards","break"],"justify_foil":"composition_order","backwards_prompt":"(f ∘ g)(x) = f(g(x)). First compute g({d}), then apply f.","break_errors":[{"type":"wrong_order","explanation":"Computed g(f({d})) = ({a}·{d}+{b})² - {c} instead of f(g({d}))."}],"tags":["composition","functions","evaluation"],"difficulty":1}
{"id":"precalc_inv_001","course":"precalc","topic":"inverse_functions","method":"inverse_find","template":"Find the inverse of f(x) = ({a}x + {b})/({c}x + {d}).","variables":{"a":{"type":"int","range":[1,4],"step":1},"b":{"type":"int","range":[1,4],"step":1},"c":{"type":"int","range":[1,4],"step":1},"d":{"type":"int","range":[1,4],"step":1}},"answer_fn":"(d*x-b)/(a-c*x)","answerNorm":"(d*x-b)/(a-c*x)","solution_steps":[{"label":"Set y = f(x)","math":"y = \\frac{{{a}x + {b}}}{{{c}x + {d}}","note":""},{"label":"Swap x and y","math":"x = \\frac{{{a}y + {b}}}{{{c}y + {d}}","note":""},{"label":"Solve for y","math":"x({c}y + {d}) = {a}y + {b} \\implies x{c}y + x{d} = {a}y + {b}","note":""},{"label":"Collect y terms","math":"y({c}x - {a}) = {b} - {d}x","note":""},{"label":"Solve for y","math":"y = \\frac{{{b} - {d}x}}{{{a} - {c}x}}","note":""}],"contexts":[{"skin":"engineering","narrative":"A feedback loop's transfer function is f(x) = ({a}x+{b})/({c}x+{d}). Find the inverse transfer function."}],"modes_available":["solve","justify","backwards","break"],"justify_foil":"algebraic_inverse_steps","backwards_prompt":"To find f^-1(x): set y = f(x), swap x and y, solve for y. Show the algebra.","break_errors":[{"type":"algebraic_error","explanation":"Solved x = (ay+b)/(cy+d) incorrectly, got y = (b-dx)/(ax-c) instead of (b-dx)/(a-cx)."}],"tags":["inverse_functions","algebraic","rational"],"difficulty":3}
{"id":"algebra_linear_001","course":"algebra","topic":"linear_equations","method":"linear_word","template":"{name} buys {a} pencils and {b} pens for ${cost}. Pens cost ${pen_price} each. How much does each pencil cost?","variables":{"name":{"type":"str","values":["Alex","Maria","Jin","Sara","Tom"]},"a":{"type":"int","range":[3,10],"step":1},"b":{"type":"int","range":[1,6],"step":1},"cost":{"type":"int","range":[5,20],"step":1},"pen_price":{"type":"int","range":[1,4],"step":1}},"answer_fn":"(cost-pen_price*b)/a","answerNorm":"pencil_price=(cost-b*pen_price)/a","solution_steps":[{"label":"Set up equation","math":"{a}p + {b}({pen_price}) = {cost}","note":"p = price of one pencil"},{"label":"Compute pen cost","math":"{b} \\times {pen_price} = {b*pen_price}","note":""},{"label":"Subtract pen cost","math":"{a}p = {cost} - {b*pen_price} = {cost - b*pen_price}","note":""},{"label":"Divide by number of pencils","math":"p = \\frac{{{cost - b*pen_price}}}{{{a}}} = \\${(cost - b*pen_price)/a:.2f}","note":""}],"contexts":[{"skin":"school","narrative":"At the school store, {name} buys {a} pencils and {b} pens for ${cost}. If pens are ${pen_price} each, what is the price of one pencil?"}],"modes_available":["solve","justify","backwards","break"],"justify_foil":"translate_word_to_equation","backwards_prompt":"Translate: {a} pencils at $p each + {b} pens at ${pen_price} each = ${cost}. Solve for p.","break_errors":[{"type":"arithmetic_error","explanation":"Computed {cost} - {b} = {cost-b} instead of {cost} - {b*pen_price}."}],"tags":["linear","word_problem","real_world"],"difficulty":1}
{"id":"algebra_quad_001","course":"algebra","topic":"quadratic_equations","method":"quadratic_word","template":"A rectangle's length is {l} more than its width. If the area is {area} cm², find the dimensions.","variables":{"l":{"type":"int","range":[2,8],"step":1},"area":{"type":"int","range":[15,60],"step":1}},"answer_fn":"solve_area_dimensions","answerNorm":"w=sqrt(area+l^2/4)-l/2","solution_steps":[{"label":"Define variables","math":"w = \\text{{width}}, \\quad l = w + {l}","note":"length is l more than width"},{"label":"Set up area equation","math":"w(w + {l}) = {area} \\implies w^2 + {l}w - {area} = 0","note":""},{"label":"Solve quadratic","math":"w = \\frac{{-{l} \\pm \\sqrt{{{l}^2 + 4{area}}}}}{{2}}","note":"Using quadratic formula"},{"label":"Take positive root","math":"w = \\frac{{-{l} + \\sqrt{{{l}^2 + {4*area}}}}}{{2}}","note":""},{"label":"Find length","math":"l = w + {l}","note":""}],"contexts":[{"skin":"construction","narrative":"A rectangular garden plot has length {l} cm longer than its width. Area = {area} cm². Find dimensions."}],"modes_available":["solve","justify","backwards","break"],"justify_foil":"quadratic_area_setup","backwards_prompt":"Area = width × (width + {l}) = {area}. Rearrange to standard quadratic form and solve.","break_errors":[{"type":"wrong_sign_in_quadratic","explanation":"Set w(w+{l}) = {area} → w²+{l}w-{area}=0 but used +{area} instead of -{area}."}],"tags":["quadratic","word_problem","geometry","area"],"difficulty":2}
{"id":"algebra_frac_001","course":"algebra","topic":"rational_expressions","method":"rate_problem","template":"{name} can paint a fence in {a} hours. Working together with {friend}, they finish in {b} hours. How long would {friend} take alone?","variables":{"name":{"type":"str","values":["Alex","Maria","Jin","Sara"]},"a":{"type":"int","range":[3,8],"step":1},"b":{"type":"int","range":[1,3],"step":1},"friend":{"type":"str","values":["Sam","Lee","Kim","Raj"]}},"answer_fn":"1/(1/b-1/a)","answerNorm":"friend_time=1/(1/b-1/a)","solution_steps":[{"label":"Rates","math":"\\text{{Alex's rate}} = 1/{a} \\text{{ of fence/hour}}","note":""},{"label":"Combined rate","math":"\\text{{Together}} = 1/{b} \\text{{ of fence/hour}}","note":""},{"label":"Friend's rate","math":"\\text{{Friend's rate}} = \\frac{1}{b} - \\frac{1}{a} = \\frac{{a-b}}{{a}{b}}","note":""},{"label":"Friend's time","math":"\\text{{Friend's time}} = \\frac{1}{{{\\frac{a-b}{ab}}}} = \\frac{{ab}}{{a-b}} \\text{{ hours}}","note":""}],"contexts":[{"skin":"home_improvement","narrative":"{name} paints a fence in {a} hours. With {friend} helping, it takes {b} hours. How long would {friend} take alone?"}],"modes_available":["solve","justify","backwards","break"],"justify_foil":"rate_addition","backwards_prompt":"Rates add: 1/T = 1/A - 1/B for combined work T. With A={a}h, T={b}h, find B.","break_errors":[{"type":"rate_subtraction","explanation":"Wrote friend rate = 1/{b} + 1/{a} instead of 1/{b} - 1/{a}."}],"tags":["rational","rate","work_problem"],"difficulty":2}
{"id":"algebra_sys_001","course":"algebra","topic":"systems","method":"system_word","template":"{name} bought {a} adult tickets and {b} child tickets for a total of ${total}. {friend} bought {c} adult tickets and {d} child tickets for ${total2}. How much is each ticket type?","variables":{"name":{"type":"str","values":["Alex","Maria","Jin","Sara","Tom"]},"a":{"type":"int","range":[1,5],"step":1},"b":{"type":"int","range":[2,6],"step":1},"c":{"type":"int","range":[1,5],"step":1},"d":{"type":"int","range":[1,4],"step":1},"total":{"type":"int","range":[30,80],"step":5},"total2":{"type":"int","range":[20,50],"step":5},"friend":{"type":"str","values":["Sam","Lee","Kim","Raj","Priya"]}},"answer_fn":"solve_ticket_system","answerNorm":"adult=(total*d-b*total2)/(a*d-b*c),child=(total-a*adult)/b","solution_steps":[{"label":"Set up equations","math":"{a}A + {b}C = {total}, \\quad {c}A + {d}C = {total2}","note":"A = adult price, C = child price"},{"label":"Eliminate C","math":"\\text{Multiply first by {d}, second by {b}, subtract: } ({a*d} - {c*b})A = {total*d} - {total2*b}","note":""},{"label":"Solve for A","math":"A = \\frac{{{total*d} - {total2*b}}}{{{a*d} - {c*b}}}","note":""},{"label":"Find C","math":"C = \\frac{{{total} - {a}A}}{{b}}","note":""}],"contexts":[{"skin":"entertainment","narrative":"{name} buys {a} adult + {b} child tickets for ${total}. {friend} buys {c} adult + {d} child tickets for ${total2}. Find adult and child prices."}],"modes_available":["solve","justify","backwards","break"],"justify_foil":"elimination_method","backwards_prompt":"Solve: {a}A + {b}C = {total}, {c}A + {d}C = {total2}. Use elimination or substitution.","break_errors":[{"type":"coefficient_mismatch","explanation":"Multiplied equations incorrectly, e.g., multiplied first by {c} and second by {a} instead of creating matching coefficients."}],"tags":["systems","word_problem","linear_combination"],"difficulty":2}